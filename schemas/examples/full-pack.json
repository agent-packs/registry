{
  "id": "full-stack-review",
  "name": "Full Stack Review Pack",
  "version": "1.0.0",
  "description": "A complete example showing every supported capability type.",
  "license": "Apache-2.0",
  "maintainers": [
    "agent-packs-maintainers"
  ],
  "stability": "stable",
  "lastVerified": "2026-06-05",
  "reviewStatus": "verified",
  "requirements": {
    "agentPacks": ">=0.1.0",
    "tools": {
      "codex": ">=0.0.0",
      "claude-code": ">=0.0.0"
    }
  },
  "tags": [
    "review",
    "full-stack",
    "github",
    "ci"
  ],
  "capabilities": [
    {
      "type": "skill",
      "name": "Code review workflow",
      "source": "https://example.com/skills/code-review/SKILL.md",
      "format": "agent-skill",
      "entry": "SKILL.md",
      "targets": [
        ".claude/skills/",
        ".codex/skills/"
      ]
    },
    {
      "type": "plugin",
      "name": "Claude Code review plugin",
      "source": "https://example.com/plugins/claude-code-review",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "install": {
        "method": "claude-marketplace",
        "marketplace": "example-marketplace",
        "package": "claude-code-review",
        "command": "claude plugin install claude-code-review@example-marketplace"
      },
      "requiresExecution": true,
      "trust": "community"
    },
    {
      "type": "command",
      "name": "Run repository tests",
      "content": "Run the repository's focused test command, then summarize failures and likely fixes.",
      "format": "markdown",
      "targets": [
        "claude",
        "codex",
        "generic"
      ]
    },
    {
      "type": "hook",
      "name": "Pre-review setup hook",
      "content": "{\"event\":\"preReview\",\"steps\":[\"git status --short\",\"detect test command\"]}",
      "format": "json",
      "targets": [
        "generic"
      ]
    },
    {
      "type": "prompt",
      "name": "Review summary prompt",
      "source": "https://example.com/prompts/review-summary.md",
      "format": "markdown-prompt"
    },
    {
      "type": "template",
      "name": "Pull request report template",
      "source": "https://example.com/templates/pr-report.md",
      "format": "template"
    },
    {
      "type": "tool",
      "name": "Browser verification tool",
      "source": "https://example.com/tools/browser-verify",
      "format": "other"
    },
    {
      "type": "memory",
      "name": "Team engineering rules",
      "content": "Run focused tests before committing.\nKeep agent-authored changes small and reviewable.",
      "format": "markdown",
      "targets": [
        "claude",
        "codex",
        "gemini",
        "opencode"
      ]
    },
    {
      "type": "memory",
      "name": "Copilot TypeScript review rules",
      "content": "Prefer explicit return types on exported TypeScript functions.",
      "format": "markdown",
      "applyTo": "src/**/*.{ts,tsx}",
      "agentTargets": {
        "copilot": {
          "destination": ".github/instructions/copilot-typescript-review-rules.instructions.md",
          "scope": "project",
          "format": "markdown"
        }
      }
    },
    {
      "type": "settings",
      "name": "Codex memories",
      "content": "{\"features\":{\"memories\":true},\"memories\":{\"use_memories\":true}}",
      "format": "toml",
      "targets": [
        "codex"
      ]
    },
    {
      "type": "mcp",
      "name": "Filesystem MCP server",
      "serverName": "filesystem",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PROJECT_DIR}"
      ]
    }
  ]
}
