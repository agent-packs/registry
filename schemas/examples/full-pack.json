{
  "id": "full-stack-review",
  "name": "Full Stack Review Pack",
  "version": "1.0.0",
  "description": "A complete example showing every supported capability type.",
  "license": "Apache-2.0",
  "maintainers": [
    "agent-packs-maintainers"
  ],
  "stability": "stable",
  "lastVerified": "2026-06-05",
  "reviewStatus": "verified",
  "trust": "community",
  "compatibility": {
    "codex": {
      "status": "verified",
      "lastVerified": "2026-06-27",
      "notes": "Reference and copy-mode dry runs verified."
    },
    "claude-code": {
      "status": "verified",
      "lastVerified": "2026-06-27"
    }
  },
  "requirements": {
    "agentPacks": ">=0.1.0",
    "tools": {
      "codex": ">=0.0.0",
      "claude-code": ">=0.0.0"
    }
  },
  "tags": [
    "review",
    "full-stack",
    "github",
    "ci"
  ],
  "capabilities": [
    {
      "type": "skill",
      "name": "Code review workflow",
      "source": "https://example.com/skills/code-review/SKILL.md",
      "format": "agent-skill",
      "entry": "SKILL.md",
      "targets": [
        ".claude/skills/",
        ".codex/skills/"
      ]
    },
    {
      "type": "plugin",
      "name": "Claude Code review plugin",
      "source": "https://example.com/plugins/claude-code-review",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "install": {
        "method": "claude-marketplace",
        "marketplace": "example-marketplace",
        "package": "claude-code-review",
        "command": "claude plugin install claude-code-review@example-marketplace"
      },
      "requiresExecution": true,
      "trust": "community"
    },
    {
      "type": "command",
      "name": "Run repository tests",
      "content": "Run the repository's focused test command, then summarize failures and likely fixes.",
      "format": "markdown"
    },
    {
      "type": "hook",
      "name": "Pre-review setup hook",
      "content": "{\"event\":\"preReview\",\"steps\":[\"git status --short\",\"detect test command\"]}",
      "format": "json"
    },
    {
      "type": "subagent",
      "name": "Code reviewer subagent",
      "content": "---\nname: code-reviewer\ndescription: Review code changes.\ntools: Read, Grep, Glob\n---\n\nReview code for correctness, maintainability, and test coverage.",
      "format": "markdown"
    },
    {
      "type": "prompt",
      "name": "Review summary prompt",
      "content": "Summarize the review findings by severity.",
      "format": "markdown"
    },
    {
      "type": "template",
      "name": "Pull request report template",
      "content": "# Pull Request Report\n\n## Summary\n\n## Risks\n",
      "format": "markdown"
    },
    {
      "type": "tool",
      "name": "Browser verification tool",
      "content": "{\"name\":\"browser-verify\",\"description\":\"Portable descriptor only; Agent Packs does not execute this.\"}",
      "format": "json"
    },
    {
      "type": "memory",
      "name": "Team engineering rules",
      "content": "Run focused tests before committing.\nKeep agent-authored changes small and reviewable.",
      "format": "markdown"
    },
    {
      "type": "settings",
      "name": "Codex memories",
      "content": "{\"features\":{\"memories\":true}}",
      "format": "toml"
    },
    {
      "type": "mcp",
      "name": "Filesystem MCP server",
      "serverName": "filesystem",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PROJECT_DIR}"
      ]
    }
  ]
}
