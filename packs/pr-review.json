{
  "id": "pr-review",
  "name": "PR Review Pack",
  "version": "0.2.0",
  "description": "A starter pack for coding agents reviewing pull requests, enforcing quality gates, and identifying regressions.",
  "license": "Apache-2.0",
  "maintainers": [
    "sandeshh"
  ],
  "stability": "experimental",
  "lastVerified": "2026-06-12",
  "reviewStatus": "reviewed",
  "tags": [
    "github",
    "review",
    "ci",
    "quality",
    "code-review"
  ],
  "skills": [
    "code-review-workflow",
    "code-review-and-quality"
  ],
  "plugins": [
    "github-pr-inspection",
    {
      "id": "claude-code-review",
      "name": "Claude Code Review",
      "source": "https://github.com/agent-packs/registry/tree/main/plugins/claude-code-review",
      "format": "anthropic-plugin",
      "entry": ".claude-plugin/plugin.json",
      "repository": "https://github.com/anthropics/claude-plugins-official",
      "trust": "official"
    }
  ],
  "categories": [
    "quality",
    "engineering"
  ],
  "tools": [
    "codex",
    "claude-code"
  ],
  "scope": [
    "global",
    "project"
  ]
}
